# ---------------------------------------------------------------------------
# Peach — Environment configuration template
#
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# `peach.config.settings.Settings` validates these on process start; missing
# required values fail loudly with a pydantic ValidationError.
# ---------------------------------------------------------------------------

# ============================================================================
# Database connection
# ============================================================================
# Format: postgresql+psycopg://user:pass@host:port/dbname
# The default below matches the `docker-compose.yml` postgres service so that
# `make db.up` followed by `alembic upgrade head` works without further setup.
DATABASE_URL=postgresql+psycopg://peach:peach@localhost:5432/peach

# ============================================================================
# JWT signing (Phase 4 onwards)
# ============================================================================
# 32+ bytes of random.  Generate locally with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate this and every issued token becomes invalid — exactly the desired
# behavior on suspected compromise.
JWT_SECRET_KEY=replace-me-with-a-real-secret-at-least-32-bytes-long
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ============================================================================
# Data source credentials (most are unauthenticated; this is for the few
# that need a User-Agent header or API key)
# ============================================================================
# SEC EDGAR requires you to identify yourself in the User-Agent header per
# their fair-use policy: https://www.sec.gov/os/accessing-edgar-data
# Format suggested by SEC: "Application-Name Contact-Email"
EDGAR_USER_AGENT=Peach-Screener admin@example.com

# FRED API key (free at https://fred.stlouisfed.org/docs/api/api_key.html).
# Only needed once Phase 10 (macro) lands; leave blank until then.
FRED_API_KEY=

# ============================================================================
# Anthropic API (Phase 11 onwards)
# ============================================================================
# Get a key at https://console.anthropic.com/.
# Leave blank until Phase 11.
ANTHROPIC_API_KEY=

# ============================================================================
# Application behavior
# ============================================================================
# Safety mode for the screener / paper-trading pipeline.  Allowed values:
#   "paper"  — simulated fills only (default; the only legal value for v1)
#   "live"   — would route to a real broker.  Out of scope for v1; the code
#              path is intentionally not implemented.
SAFETY_MODE=paper

# Logging — "INFO" or "DEBUG" during development, "WARNING" in production.
LOG_LEVEL=INFO
