# ---------------------------------------------------------------------------
# Python build / runtime artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ---------------------------------------------------------------------------
# Virtual environments — uv creates `.venv/` by default
# ---------------------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Secrets — NEVER commit these.  `.env.example` is the committed template.
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ---------------------------------------------------------------------------
# Data artifacts — generated by ingestion / backtests / agents.  These can
# get large quickly; the database is the source of truth, not these files.
# ---------------------------------------------------------------------------
data/
*.parquet
*.feather
*.xlsx
*.log
backtest_artifacts/
agent_logs/

# ---------------------------------------------------------------------------
# Local docker volumes (when bind-mounted)
# ---------------------------------------------------------------------------
.postgres_data/
.pgadmin_data/
